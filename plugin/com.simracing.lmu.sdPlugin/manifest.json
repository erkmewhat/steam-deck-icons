{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
    "Name": "LMU Sim Racing",
    "Version": "1.0.0.0",
    "Author": "Charles Costello",
    "Description": "Stream Deck hotkey actions for Le Mans Ultimate sim racing. Control pit limiter, headlights, wipers, MFD navigation, brake bias, traction control, and more.",
    "Icon": "imgs/plugin-icon",
    "UUID": "com.simracing.lmu",
    "SDKVersion": 2,
    "CodePath": "bin/plugin.js",
    "Category": "LMU Sim Racing",
    "CategoryIcon": "imgs/category-icon",
    "Nodejs": {
        "Version": "20",
        "Debug": "enabled"
    },
    "Software": {
        "MinimumVersion": "6.7"
    },
    "OS": [
        {
            "Platform": "windows",
            "MinimumVersion": "10"
        }
    ],
