{
  "name": "com.simracing.lmu",
  "type": "module",
  "version": "1.0.0",
  "description": "Stream Deck plugin for Le Mans Ultimate sim racing hotkey actions",
  "main": "com.simracing.lmu.sdPlugin/bin/plugin.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');function fix(d){fs.readdirSync(d).forEach(f=>{const p=path.join(d,f);if(fs.statSync(p).isDirectory())fix(p);else if(f.endsWith('.js')){let c=fs.readFileSync(p,'utf8');c=c.replace(/from ['\\\"](\\.\\/.+?)['\\\"]/g,(m,i)=>i.endsWith('.js')?m:m.replace(i,i+'.js'));fs.writeFileSync(p,c)}})}fix('com.simracing.lmu.sdPlugin/bin')\"",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.4",
    "@resvg/resvg-js": "^2.6.2",
    "gif-encoder-2": "^1.0.5",
    "koffi": "^2.15.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
