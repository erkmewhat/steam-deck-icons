{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "outDir": "com.simracing.lmu.sdPlugin/bin",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "experimentalDecorators": true,
        "declaration": false,
        "sourceMap": false
    },
    "include": ["src/**/*.ts"]
}
