            "UUID": "com.simracing.ace.pit-limiter",
            "Name": "Pit Limiter",
            "Icon": "imgs/actions/pit-limiter",
            "Tooltip": "Toggle pit lane speed limiter",
            "Controllers": ["Keypad"],
            "States": [
                {
                    "Image": "imgs/actions/pit-limiter",
                    "Name": "Pit Limiter",
                    "ShowTitle": true,
                    "TitleAlignment": "bottom",
                    "TitleColor": "#FFFFFF"
                }
            ]
        },
        {
