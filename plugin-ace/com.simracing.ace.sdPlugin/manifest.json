{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
    "Name": "ACE Sim Racing",
    "Version": "1.0.0.0",
    "Author": "Charles Costello",
    "Description": "Assetto Corsa Evo sim racing controls. Send configurable keyboard hotkeys for pit limiter, headlights, wipers, traction control, ABS, engine maps, brake bias, and more.",
    "Icon": "imgs/plugin-icon",
    "UUID": "com.simracing.ace",
    "SDKVersion": 2,
    "CodePath": "bin/plugin.js",
    "Category": "ACE Sim Racing",
    "CategoryIcon": "imgs/category-icon",
    "Nodejs": {
        "Version": "20",
        "Debug": "enabled"
    },
    "Software": {
        "MinimumVersion": "6.7"
    },
    "OS": [
        {
            "Platform": "windows",
            "MinimumVersion": "10"
        }
    ],
    "Actions": [
